{
  "compilerOptions": {
    "target": "ES2020",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "next-auth": [
        "./lib/shims/next-auth/index.ts"
      ],
      "next-auth/*": [
        "./lib/shims/next-auth/*"
      ],
      "bcryptjs": [
        "./lib/shims/bcryptjs.ts"
      ],
      "zod": [
        "./lib/shims/zod.ts"
      ],
      "@prisma/client": [
        "./lib/shims/prisma-client.ts"
      ]
    },
    "baseUrl": "."
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
