DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME"
ADMIN_TOKEN="replace-with-a-long-random-secret"
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
NEXTAUTH_URL="http://localhost:3000"

# Optional: Vercel Upstash KV (custom prefix "STORAGE")
# In the Vercel connect dialog (prefix STORAGE + suffix _URL), use the Redis URL value below.
STORAGE_URL="redis://default:<password>@<region>-<id>.upstash.io:6379"

# Variables Vercel exposes after connecting Upstash KV with prefix STORAGE.
STORAGE_KV_REST_API_READ_ONLY_TOKEN="<upstash-readonly-rest-token>"
STORAGE_KV_REST_API_TOKEN="<upstash-rest-token>"
STORAGE_KV_REST_API_URL="https://<region>-<id>.upstash.io"
STORAGE_KV_URL="<upstash-kv-url>"
STORAGE_REDIS_URL="redis://default:<password>@<region>-<id>.upstash.io:6379"
