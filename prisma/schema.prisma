generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Mosque {
  id            String   @id @default(cuid())
  name          String
  city          String
  country       String
  madhab        String?
  prayerTimes   String?
  services      String[]
  latitude      Float
  longitude     Float
  announcements Announcement[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  body      String
  mosqueId  String
  mosque    Mosque   @relation(fields: [mosqueId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
